# Sanity CMS Configuration
VUE_APP_SANITY_PROJECT_ID=w696z6zz
VUE_APP_SANITY_DATASET=portfolio-thaiseboy
VUE_APP_SANITY_API_VERSION=2023-01-01
VUE_APP_SANITY_USE_CDN=true

# Do not put Sanity write tokens in VUE_APP_* variables.
# Public portfolio reads should work without a token.

# Application Configuration
VUE_APP_URL=http://localhost:8080
VUE_APP_NAME=Portfolio

# Email Service Configuration
# Set this to use a proper email service instead of mailto
# Example: https://formspree.io/f/YOUR_FORM_ID
VUE_APP_EMAIL_API_URL=
